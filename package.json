{
  "name": "vgmf-fellowship-portal",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/generate-seo-static.mjs && prisma generate && next build",
    "start": "node scripts/start-with-keepalive.mjs",
    "start:next": "next start -H 0.0.0.0",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --accept-data-loss",
    "render:build": "npm run db:push && npm run db:seed-cms && npm run build",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:update-admin": "tsx prisma/update-admin.ts",
    "db:seed-cms": "tsx prisma/seed-cms.ts",
    "keepalive": "node scripts/render-keepalive.mjs",
    "keepalive:once": "node scripts/render-keepalive.mjs --once"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@prisma/client": "^6.9.0",
    "@tailwindcss/postcss": "^4.1.8",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "jose": "^6.0.11",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.19.1",
    "prisma": "^6.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "setu-client": "^1.0.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "tsx": "^4.19.4"
  }
}
