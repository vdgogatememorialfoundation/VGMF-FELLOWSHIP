generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  APPLICANT
  ADMIN
  STAFF
  COMMITTEE
  TRUSTEE
  FINANCE
}

enum ApplicationStatus {
  DRAFT
  INCOMPLETE
  SUBMITTED
  WITHDRAWN
  QUERY_RAISED
  QUERY_RESPONDED
  SCRUTINY
  SCRUTINY_APPROVED
  ELIGIBILITY_CHECK
  ELIGIBLE
  CONDITIONALLY_ELIGIBLE
  NOT_ELIGIBLE
  UNDER_REVIEW
  TECHNICAL_SCORING
  SHORTLISTED
  WAITLISTED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  TRUSTEE_REVIEW
  SELECTED
  AGREEMENT_PENDING
  REJECTED
  SUSPENDED
  TERMINATED
  COMPLETED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  NO_SHOW
}

enum FellowshipStage {
  AGREEMENT_PENDING
  BANK_VERIFICATION
  SANCTIONED
  INSTALLMENT_1_RELEASED
  QUARTERLY_REVIEW_1
  QUARTERLY_REVIEW_2
  MID_TERM_REVIEW
  INSTALLMENT_2_RELEASED
  QUARTERLY_REVIEW_3
  QUARTERLY_REVIEW_4
  FINAL_SUBMISSION
  FINANCIAL_VERIFICATION
  FINAL_PRESENTATION
  INSTALLMENT_3_RELEASED
  COMPLETED
  SUSPENDED
  TERMINATED
}

enum DocumentType {
  CV
  REGISTRATION_CERTIFICATE
  NCISM_REGISTRATION
  RESEARCH_PROPOSAL_PDF
  BUDGET_PROPOSAL_PDF
  TIMELINE_PDF
  ETHICAL_CLEARANCE
  PUBLICATIONS
  RECOMMENDATION_LETTER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMIT_REQUIRED
}

enum ResearchArea {
  MUSCULOSKELETAL_DISORDERS
  PAIN_MANAGEMENT
  NEUROLOGICAL_DISORDERS
  COMPARATIVE_STUDIES
  MECHANISM_BASED_RESEARCH
  CLASSICAL_DOCUMENTATION
  PROTOCOL_DEVELOPMENT
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ProgressReportStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REVISION_REQUIRED
}

enum InstallmentStatus {
  PENDING
  APPROVED
  RELEASED
}

enum FellowshipDocType {
  ACCEPTANCE_LETTER
  BANK_VERIFICATION
  PROGRESS_REPORT
  UTILIZATION_STATEMENT
  FINAL_REPORT
  PUBLICATION_MANUSCRIPT
  UTILIZATION_CERTIFICATE
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  BOTH
}

enum OtpPurpose {
  REGISTER
  LOGIN
  RESET_PASSWORD
}

enum FormFieldType {
  TEXT
  EMAIL
  PHONE
  NUMBER
  DATE
  TEXTAREA
  SELECT
  RADIO
  CHECKBOX
  FILE
}

enum CmsPageSlug {
  ABOUT
  TERMS
  UNDERTAKING
  RULEBOOK
  PRIVACY
  REFUND
}

model User {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  email         String   @unique
  phone         String?  @unique
  passwordHash   String   @map("password_hash")
  adminPassword  String?  @map("admin_password")
  role           UserRole @default(APPLICANT)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  profile              Profile?
  applications         Application[]
  committeeScores      CommitteeScore[]
  committeeRemarks     CommitteeRemark[]
  trusteeApprovals     TrusteeApproval[]
  notifications        Notification[]
  sessions             Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  name      String
  dob       DateTime?
  gender    Gender?
  address   String?
  city      String?
  state     String?
  country   String?  @default("India")
  pincode   String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Application {
  id                    String            @id @default(cuid())
  applicationNumber     String            @unique @map("application_number")
  userId                String            @map("user_id")
  status                ApplicationStatus @default(DRAFT)
  rejectionReason       String?           @map("rejection_reason")
  adminNotes            String?           @map("admin_notes")

  // Personal Details
  name                  String
  dob                   DateTime
  gender                Gender
  address               String
  city                  String
  state                 String
  country               String            @default("India")
  pincode               String
  mobile                String
  email                 String

  // Professional Details
  bamsCollege           String            @map("bams_college")
  yearOfPassing         Int               @map("year_of_passing")
  mdMsPhdDetails        String?           @map("md_ms_phd_details")
  currentDesignation    String            @map("current_designation")
  institutionName       String            @map("institution_name")
  registrationCouncil   String            @map("registration_council")
  registrationNumber    String            @map("registration_number")
  yearsOfPractice       Int               @map("years_of_practice")
  viddhakarmaExperience String?           @map("viddhakarma_experience")
  publicationsSummary   String?           @map("publications_summary")
  termsAcceptedAt       DateTime?         @map("terms_accepted_at")
  undertakingAcceptedAt DateTime?         @map("undertaking_accepted_at")
  verificationNotes     String?           @map("verification_notes")
  eligibilityNotes      String?           @map("eligibility_notes")
  queryNotes            String?           @map("query_notes")

  submittedAt           DateTime?         @map("submitted_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  researchProposal  ResearchProposal?
  budget            Budget?
  documents         ApplicationDocument[]
  committeeScores   CommitteeScore[]
  committeeRemarks  CommitteeRemark[]
  interview         Interview?
  trusteeApproval   TrusteeApproval?
  fellowship        Fellowship?
  statusHistory     ApplicationStatusHistory[]
  digitalUndertaking DigitalUndertaking?

  @@map("applications")
}

model ApplicationStatusHistory {
  id            String            @id @default(cuid())
  applicationId String            @map("application_id")
  fromStatus    ApplicationStatus? @map("from_status")
  toStatus      ApplicationStatus @map("to_status")
  changedBy     String?           @map("changed_by")
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_status_history")
}

model DigitalUndertaking {
  id                   String   @id @default(cuid())
  applicationId        String   @unique @map("application_id")
  fullName             String   @map("full_name")
  agreeFellowshipRules Boolean  @map("agree_fellowship_rules")
  certifyInfoCorrect   Boolean  @map("certify_info_correct")
  agreeFundUtilization Boolean  @map("agree_fund_utilization")
  signaturePath        String   @map("signature_path")
  signatureType        String   @map("signature_type")
  pdfPath              String   @map("pdf_path")
  pdfData              String?  @map("pdf_data") @db.Text
  signatureData        String?  @map("signature_data") @db.Text
  ipAddress            String   @map("ip_address")
  submittedAt          DateTime @default(now()) @map("submitted_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("digital_undertakings")
}

model FellowshipDocument {
  id              String            @id @default(cuid())
  fellowshipId    String            @map("fellowship_id")
  installmentNo   Int               @map("installment_no")
  type            FellowshipDocType
  fileName        String            @map("file_name")
  filePath        String            @map("file_path")
  fileSize        Int               @map("file_size")
  mimeType        String            @map("mime_type")
  status          DocumentStatus    @default(PENDING)
  rejectionReason String?           @map("rejection_reason")
  uploadedAt      DateTime          @default(now()) @map("uploaded_at")
  reviewedAt      DateTime?         @map("reviewed_at")
  reviewedBy      String?           @map("reviewed_by")

  fellowship Fellowship @relation(fields: [fellowshipId], references: [id], onDelete: Cascade)

  @@unique([fellowshipId, installmentNo, type])
  @@map("fellowship_documents")
}

model ResearchProposal {
  id                String       @id @default(cuid())
  applicationId     String       @unique @map("application_id")
  projectTitle      String       @map("project_title")
  researchArea      ResearchArea @map("research_area")
  researchAreaOther String?      @map("research_area_other")
  objectives        String
  methodology       String
  sampleSize        String       @map("sample_size")
  studyDuration     String       @map("study_duration")
  expectedOutcomes  String       @map("expected_outcomes")
  budgetSummary     String       @map("budget_summary")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("research_proposals")
}

model Budget {
  id            String   @id @default(cuid())
  applicationId String   @unique @map("application_id")
  equipment     Float    @default(0)
  consumables   Float    @default(0)
  travel        Float    @default(0)
  documentation Float    @default(0)
  publication   Float    @default(0)
  other         Float    @default(0)
  total         Float    @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("budgets")
}

model ApplicationDocument {
  id              String         @id @default(cuid())
  applicationId   String         @map("application_id")
  type            DocumentType
  fileName        String         @map("file_name")
  filePath        String         @map("file_path")
  fileSize        Int            @map("file_size")
  mimeType        String         @map("mime_type")
  status          DocumentStatus @default(PENDING)
  rejectionReason String?        @map("rejection_reason")
  uploadedAt      DateTime       @default(now()) @map("uploaded_at")
  reviewedAt      DateTime?      @map("reviewed_at")
  reviewedBy      String?        @map("reviewed_by")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_documents")
}

model CommitteeScore {
  id              String   @id @default(cuid())
  applicationId   String   @map("application_id")
  committeeUserId String   @map("committee_user_id")
  scientificMerit Float    @map("scientific_merit")
  innovation      Float
  feasibility     Float
  budgetJustification Float @map("budget_justification")
  viddhakarmaRelevance Float @map("viddhakarma_relevance")
  totalScore      Float    @map("total_score")
  remarks         String?
  isShortlisted   Boolean  @default(false) @map("is_shortlisted")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  committeeUser User        @relation(fields: [committeeUserId], references: [id])

  @@unique([applicationId, committeeUserId])
  @@map("committee_scores")
}

model CommitteeRemark {
  id              String   @id @default(cuid())
  applicationId   String   @map("application_id")
  committeeUserId String   @map("committee_user_id")
  remark          String
  createdAt       DateTime @default(now()) @map("created_at")

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  committeeUser User        @relation(fields: [committeeUserId], references: [id])

  @@map("committee_remarks")
}

model Interview {
  id            String   @id @default(cuid())
  applicationId String   @unique @map("application_id")
  scheduledDate DateTime @map("scheduled_date")
  scheduledTime String   @map("scheduled_time")
  meetingLink   String   @map("meeting_link")
  panelMembers  String   @map("panel_members")
  status        InterviewStatus @default(SCHEDULED)
  feedback      String?
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("interviews")
}

model TrusteeApproval {
  id              String   @id @default(cuid())
  applicationId   String   @unique @map("application_id")
  trusteeUserId   String   @map("trustee_user_id")
  approved        Boolean
  remarks         String?
  digitalSignature String? @map("digital_signature")
  approvedAt      DateTime @default(now()) @map("approved_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  trusteeUser User        @relation(fields: [trusteeUserId], references: [id])

  @@map("trustee_approvals")
}

model Fellowship {
  id               String   @id @default(cuid())
  fellowshipId     String   @unique @map("fellowship_id")
  applicationId    String   @unique @map("application_id")
  fellowName       String   @map("fellow_name")
  projectTitle     String   @map("project_title")
  sanctionedAmount Float    @map("sanctioned_amount")
  duration         String
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  awardLetterPath  String?  @map("award_letter_path")
  mentor           String?
  institution      String?
  currentStage     FellowshipStage @default(AGREEMENT_PENDING) @map("current_stage")
  isActive         Boolean  @default(true) @map("is_active")
  isCompleted      Boolean  @default(false) @map("is_completed")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  application      Application       @relation(fields: [applicationId], references: [id])
  installments     FundInstallment[]
  progressReports  ProgressReport[]
  midTermReviews   MidTermReview[]
  finalSubmission  FinalSubmission?
  financeRecords   FinanceRecord?
  certificates     Certificate[]
  fellowshipDocuments FellowshipDocument[]
  reminders        FellowshipReminder[]

  @@map("fellowships")
}

model FundInstallment {
  id              String            @id @default(cuid())
  fellowshipId    String            @map("fellowship_id")
  installmentNo   Int               @map("installment_no")
  percentage      Float
  amount          Float
  status          InstallmentStatus @default(PENDING)
  paymentDate     DateTime?         @map("payment_date")
  transactionId   String?           @map("transaction_id")
  approvalNotes   String?           @map("approval_notes")
  releasedAt      DateTime?         @map("released_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  fellowship Fellowship @relation(fields: [fellowshipId], references: [id], onDelete: Cascade)

  @@unique([fellowshipId, installmentNo])
  @@map("fund_installments")
}

model ProgressReport {
  id              String               @id @default(cuid())
  fellowshipId    String               @map("fellowship_id")
  quarter         Int
  year            Int
  reportPath      String?              @map("report_path")
  caseRecordsPath String?              @map("case_records_path")
  photosPath      String?              @map("photos_path")
  publicationsPath String?             @map("publications_path")
  activitiesCompleted String?          @map("activities_completed")
  casesEnrolled    Int?                 @map("cases_enrolled")
  expenditure      Float?               @map("expenditure")
  progressUpdate   String?              @map("progress_update")
  dataStatus       String?              @map("data_status")
  analysisUpdate   String?              @map("analysis_update")
  finalResults     String?              @map("final_results")
  dueDate          DateTime?            @map("due_date")
  status          ProgressReportStatus @default(SUBMITTED)
  reviewNotes     String?              @map("review_notes")
  submittedAt     DateTime             @default(now()) @map("submitted_at")
  reviewedAt      DateTime?            @map("reviewed_at")

  fellowship Fellowship @relation(fields: [fellowshipId], references: [id], onDelete: Cascade)

  @@unique([fellowshipId, quarter, year])
  @@map("progress_reports")
}

model MidTermReview {
  id              String   @id @default(cuid())
  fellowshipId    String   @map("fellowship_id")
  reviewerId      String   @map("reviewer_id")
  progressScore   Float    @map("progress_score")
  remarks         String?
  nextInstallmentApproved Boolean @default(false) @map("next_installment_approved")
  reviewedAt      DateTime @default(now()) @map("reviewed_at")

  fellowship Fellowship @relation(fields: [fellowshipId], references: [id], onDelete: Cascade)

  @@map("mid_term_reviews")
}

model FinalSubmission {
  id                    String   @id @default(cuid())
  fellowshipId          String   @unique @map("fellowship_id")
  finalReportPath       String?  @map("final_report_path")
  manuscriptPath        String?  @map("manuscript_path")
  utilizationCertPath   String?  @map("utilization_cert_path")
  billsVouchersPath     String?  @map("bills_vouchers_path")
  presentationPath      String?  @map("presentation_path")
  status                ProgressReportStatus @default(SUBMITTED)
  submittedAt           DateTime @default(now()) @map("submitted_at")
  reviewedAt            DateTime? @map("reviewed_at")

  fellowship Fellowship @relation(fields: [fellowshipId], references: [id], onDelete: Cascade)

  @@map("final_submissions")
}

model FinanceRecord {
  id                    String   @id @default(cuid())
  fellowshipId          String   @unique @map("fellowship_id")
  sanctionedAmount      Float    @map("sanctioned_amount")
  releasedAmount        Float    @default(0) @map("released_amount")
  balanceAmount         Float    @map("balance_amount")
  utilizationCertPath   String?  @map("utilization_cert_path")
  pendingDocuments      String?  @map("pending_documents")
  updatedAt             DateTime @updatedAt @map("updated_at")

  fellowship Fellowship @relation(fields: [fellowshipId], references: [id], onDelete: Cascade)

  @@map("finance_records")
}

model Certificate {
  id              String   @id @default(cuid())
  fellowshipId    String   @map("fellowship_id")
  type            String
  filePath        String   @map("file_path")
  digitalSignature String? @map("digital_signature")
  issuedAt        DateTime @default(now()) @map("issued_at")

  fellowship Fellowship @relation(fields: [fellowshipId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model FellowshipReminder {
  id            String   @id @default(cuid())
  fellowshipId  String   @map("fellowship_id")
  quarter       Int
  year          Int
  dueDate       DateTime @map("due_date")
  reminder30Sent Boolean @default(false) @map("reminder_30_sent")
  reminder15Sent Boolean @default(false) @map("reminder_15_sent")
  reminderDueSent Boolean @default(false) @map("reminder_due_sent")
  overdueEscalated Boolean @default(false) @map("overdue_escalated")
  createdAt     DateTime @default(now()) @map("created_at")

  fellowship Fellowship @relation(fields: [fellowshipId], references: [id], onDelete: Cascade)

  @@unique([fellowshipId, quarter, year])
  @@map("fellowship_reminders")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  title     String
  message   String
  channel   NotificationChannel @default(BOTH)
  isRead    Boolean             @default(false) @map("is_read")
  sentAt    DateTime            @default(now()) @map("sent_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  subject   String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("support_tickets")
}

model OtpCode {
  id        String     @id @default(cuid())
  phone     String?
  email     String?
  code      String
  purpose   OtpPurpose @default(REGISTER)
  expiresAt DateTime   @map("expires_at")
  verified  Boolean    @default(false)
  attempts  Int        @default(0)
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([phone, purpose])
  @@index([email, purpose])
  @@map("otp_codes")
}

model SiteSettings {
  id                    String   @id @default("default")
  siteName              String   @default("Vaidya Gogate Memorial Foundation Fellowship Portal 2026") @map("site_name")
  siteTagline           String?  @map("site_tagline")
  logoUrl               String?  @map("logo_url")
  logoData              String?  @map("logo_data") @db.Text
  logoMimeType          String?  @map("logo_mime_type")
  faviconUrl            String?  @map("favicon_url")
  faviconData           String?  @map("favicon_data") @db.Text
  faviconMimeType       String?  @map("favicon_mime_type")
  headerOrgName         String?  @map("header_org_name")
  utilityBarText        String?  @map("utility_bar_text")
  tickerText            String?  @map("ticker_text")
  tickerEnabled         Boolean  @default(true) @map("ticker_enabled")
  heroTitle             String?  @map("hero_title")
  heroSubtitle          String?  @map("hero_subtitle")
  heroBadge             String?  @map("hero_badge")
  heroStats             Json?    @map("hero_stats")
  heroSnapshot          Json?    @map("hero_snapshot")
  highlightsTitle       String?  @map("highlights_title")
  highlightsSubtitle    String?  @map("highlights_subtitle")
  highlights            Json?    @map("highlights")
  journeyTitle          String?  @map("journey_title")
  journeySubtitle       String?  @map("journey_subtitle")
  journeySteps          Json?    @map("journey_steps")
  aboutBadge            String?  @map("about_badge")
  aboutTitle            String?  @map("about_title")
  aboutContent          String?  @map("about_content") @db.Text
  aboutCtaLabel         String?  @map("about_cta_label")
  aboutCtaHref          String?  @map("about_cta_href")
  faqTitle              String?  @map("faq_title")
  faqSubtitle           String?  @map("faq_subtitle")
  faqItems              Json?    @map("faq_items")
  navLinks              Json?    @map("nav_links")
  footerQuickLinks      Json?    @map("footer_quick_links")
  footerLegalLinks      Json?    @map("footer_legal_links")
  footerAboutText       String?  @map("footer_about_text")
  footerDeveloperCredit String?  @map("footer_developer_credit")
  footerText            String?  @map("footer_text")
  contactEmail          String?  @map("contact_email")
  contactPhone          String?  @map("contact_phone")
  contactAddress        String?  @map("contact_address")
  signupEnabled         Boolean  @default(true) @map("signup_enabled")
  loginEnabled          Boolean  @default(true) @map("login_enabled")
  signupDisabledMessage String?  @map("signup_disabled_message") @db.Text
  loginDisabledMessage  String?  @map("login_disabled_message") @db.Text
  signupOtpEmailEnabled            Boolean @default(true) @map("signup_otp_email_enabled")
  signupOtpWhatsappEnabled         Boolean @default(true) @map("signup_otp_whatsapp_enabled")
  applicationNotifyEmailEnabled    Boolean @default(true) @map("application_notify_email_enabled")
  applicationNotifyWhatsappEnabled Boolean @default(true) @map("application_notify_whatsapp_enabled")
  welcomeEmailEnabled              Boolean @default(true) @map("welcome_email_enabled")
  welcomeWhatsappEnabled           Boolean @default(false) @map("welcome_whatsapp_enabled")
  alertsEmailEnabled               Boolean @default(true) @map("alerts_email_enabled")
  alertsWhatsappEnabled            Boolean @default(true) @map("alerts_whatsapp_enabled")
  statusNotifyEmailEnabled         Boolean @default(true) @map("status_notify_email_enabled")
  statusNotifyWhatsappEnabled      Boolean @default(true) @map("status_notify_whatsapp_enabled")
  maintenanceModeEnabled           Boolean @default(false) @map("maintenance_mode_enabled")
  maintenanceMessage               String? @map("maintenance_message") @db.Text
  maintenanceAllowPortals          Boolean @default(true) @map("maintenance_allow_portals")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model IntegrationSettings {
  id                          String   @id @default("default")
  appUrl                      String?  @map("app_url")
  zeptomailToken              String?  @map("zeptomail_token")
  zeptomailFromEmail          String?  @map("zeptomail_from_email")
  zeptomailFromName           String?  @map("zeptomail_from_name")
  whatsappToken               String?  @map("whatsapp_token")
  whatsappPhoneNumberId       String?  @map("whatsapp_phone_number_id")
  whatsappOtpTemplateName     String?  @map("whatsapp_otp_template_name")
  whatsappOtpTemplateLanguage String?  @map("whatsapp_otp_template_language")
  whatsappApiVersion          String?  @map("whatsapp_api_version")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("integration_settings")
}

model CmsPage {
  id          String     @id @default(cuid())
  slug        CmsPageSlug @unique
  title       String
  content     String     @db.Text
  isPublished Boolean    @default(true) @map("is_published")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("cms_pages")
}

enum NoticeCategory {
  EVENT
  DEADLINE
  GENERAL
  URGENT
  RESULT
}

model Notice {
  id                 String         @id @default(cuid())
  title              String
  content            String         @db.Text
  category           NoticeCategory @default(GENERAL)
  linkUrl            String?        @map("link_url")
  linkLabel          String?        @map("link_label")
  attachmentFileName String?        @map("attachment_file_name")
  attachmentMimeType String?        @map("attachment_mime_type")
  attachmentData     String?        @map("attachment_data") @db.Text
  isActive           Boolean        @default(true) @map("is_active")
  priority           Int            @default(0)
  publishedAt        DateTime       @default(now()) @map("published_at")
  expiresAt          DateTime?      @map("expires_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  @@map("notices")
}

model FormTemplate {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  description   String?
  isActive      Boolean         @default(true) @map("is_active")
  opensAt       DateTime?       @map("opens_at")
  closesAt      DateTime?       @map("closes_at")
  closedMessage String?         @map("closed_message") @db.Text
  fields        FormField[]
  submissions   FormSubmission[]
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@map("form_templates")
}

model FormField {
  id             String        @id @default(cuid())
  formTemplateId String        @map("form_template_id")
  section        String        @default("General")
  label          String
  fieldKey       String        @map("field_key")
  fieldType      FormFieldType @map("field_type")
  placeholder    String?
  helpText       String?       @map("help_text")
  required       Boolean       @default(false)
  options        String?
  order          Int           @default(0)
  isActive       Boolean       @default(true) @map("is_active")
  formTemplate   FormTemplate  @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)

  @@unique([formTemplateId, fieldKey])
  @@map("form_fields")
}

model FormSubmission {
  id             String       @id @default(cuid())
  formTemplateId String       @map("form_template_id")
  userId         String       @map("user_id")
  applicationId  String?      @map("application_id")
  data           Json
  status         String       @default("DRAFT")
  submittedAt    DateTime?    @map("submitted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  formTemplate FormTemplate @relation(fields: [formTemplateId], references: [id])

  @@map("form_submissions")
}
