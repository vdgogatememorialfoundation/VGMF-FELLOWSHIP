generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  APPLICANT
  ADMIN
  COADMIN
  STAFF
  COMMITTEE
  TRUSTEE
  FINANCE
}

enum ApplicationStatus {
  DRAFT
  INCOMPLETE
  SUBMITTED
  WITHDRAWN
  QUERY_RAISED
  QUERY_RESPONDED
  SCRUTINY
  SCRUTINY_APPROVED
  ELIGIBILITY_CHECK
  ELIGIBLE
  CONDITIONALLY_ELIGIBLE
  NOT_ELIGIBLE
  UNDER_REVIEW
  TECHNICAL_SCORING
  SHORTLISTED
  WAITLISTED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  TRUSTEE_REVIEW
  SELECTED
  AGREEMENT_PENDING
  REJECTED
  SUSPENDED
  TERMINATED
  COMPLETED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  NO_SHOW
  CANCELLED
  RESCHEDULED
}

enum InterviewType {
  ONLINE
  IN_PERSON
}

enum FellowshipStage {
  AGREEMENT_PENDING
  BANK_VERIFICATION
  SANCTIONED
  INSTALLMENT_1_RELEASED
  QUARTERLY_REVIEW_1
  QUARTERLY_REVIEW_2
  MID_TERM_REVIEW
  INSTALLMENT_2_RELEASED
  QUARTERLY_REVIEW_3
  QUARTERLY_REVIEW_4
  FINAL_SUBMISSION
  FINANCIAL_VERIFICATION
  FINAL_PRESENTATION
  INSTALLMENT_3_RELEASED
  COMPLETED
  TERMINATED
}

enum DocumentType {
  CV
  REGISTRATION_CERTIFICATE
  NCISM_REGISTRATION
  RESEARCH_PROPOSAL_PDF
  BUDGET_PROPOSAL_PDF
  TIMELINE_PDF
  ETHICAL_CLEARANCE
  PUBLICATIONS
  RECOMMENDATION_LETTER
  GOVERNMENT_ID
  IDENTITY_SELFIE
  AGE_PROOF
  IDENTITY_PROOF
  OTHER_SUPPORTING
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMIT_REQUIRED
}

enum ResearchArea {
  MUSCULOSKELETAL_DISORDERS
  PAIN_MANAGEMENT
  NEUROLOGICAL_DISORDERS
  COMPARATIVE_STUDIES
  MECHANISM_BASED_RESEARCH
  CLASSICAL_DOCUMENTATION
  PROTOCOL_DEVELOPMENT
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ProgressReportStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REVISION_REQUIRED
}

enum InstallmentStatus {
  PENDING
  APPROVED
  RELEASED
}

enum FellowshipDocType {
  ACCEPTANCE_LETTER
  FELLOWSHIP_AGREEMENT
  BANK_VERIFICATION
  PROGRESS_REPORT
  UTILIZATION_STATEMENT
  FINAL_REPORT
  PUBLICATION_MANUSCRIPT
  UTILIZATION_CERTIFICATE
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  BOTH
}

enum ReviewPhase {
  COMMITTEE
  TRUSTEE
  VERIFICATION
}

enum VerificationPurpose {
  APPLICANT_IDENTITY
  BANK_ACCOUNT
  UNDERTAKING_IDENTITY

  @@map("VerificationPurpose")
}

enum VerificationStatus {
  NOT_STARTED
  IN_PROGRESS
  APPROVED
  DECLINED
  IN_REVIEW
  ABANDONED
  EXPIRED

  @@map("VerificationStatus")
}

enum ApplicationQueryStatus {
  OPEN
  RESPONDED
  RESOLVED
}

enum OtpPurpose {
  REGISTER
  LOGIN
  RESET_PASSWORD
}

enum FormFieldType {
  TEXT
  EMAIL
  PHONE
  NUMBER
  DATE
  TEXTAREA
  SELECT
  RADIO
  CHECKBOX
  FILE
}

enum CmsPageSlug {
  ABOUT
  TERMS
  UNDERTAKING
  RULEBOOK
  PRIVACY
  REFUND
}

// ============================================
// NEW ENUMS FOR THREE-LAYER WORKFLOW SYSTEM
// ============================================

// Applicant-facing public statuses (simplified view)
enum ApplicantPublicStatus {
  APPLICATION_SUBMITTED
  DOCUMENTS_UNDER_VERIFICATION
  ELIGIBILITY_ASSESSMENT
  PROPOSAL_UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  FINAL_DECISION_PENDING
  SELECTED
  WAITLISTED
  NOT_SELECTED
  FELLOWSHIP_ACCEPTED
  AGREEMENT_SUBMITTED
  ETHICS_APPROVAL_PENDING
  FIRST_INSTALLMENT_RELEASED
  PROGRESS_REPORT_DUE
  MID_TERM_REVIEW
  SECOND_INSTALLMENT_RELEASED
  FINAL_REPORT_SUBMITTED
  FELLOWSHIP_COMPLETED
}

// Internal admin granular statuses
enum InternalAdminStatus {
  // Administrative
  DRAFT
  SUBMITTED
  PAYMENT_VERIFIED
  ADMINISTRATIVE_SCRUTINY
  DOCUMENTS_VERIFIED
  DOCUMENTS_REJECTED
  CLARIFICATION_REQUESTED
  
  // Eligibility
  ELIGIBILITY_PENDING
  ELIGIBLE
  NOT_ELIGIBLE
  
  // Proposal Assignment
  REVIEWER_ASSIGNED
  REVIEWER_ACCEPTED
  REVIEWER_DECLINED
  SECOND_REVIEWER_ASSIGNED
  STATISTICIAN_ASSIGNED
  SUBJECT_EXPERT_ASSIGNED
  ETHICS_EXPERT_ASSIGNED
  
  // Proposal Review
  SCIENTIFIC_REVIEW_STARTED
  METHODOLOGY_REVIEW
  LITERATURE_REVIEW
  BUDGET_REVIEW
  STATISTICAL_REVIEW
  ETHICS_REVIEW
  REVIEWER_SUBMITTED
  AWAITING_SECOND_REVIEWER
  REVIEWS_CONSOLIDATED
  
  // Committee
  COMMITTEE_DISCUSSION
  INTERVIEW_REQUIRED
  INTERVIEW_WAIVED
  AWAITING_COMMITTEE_DECISION
  TRUSTEE_APPROVAL_PENDING
  APPROVED
  WAITLISTED
  REJECTED
  
  // Fellowship
  AGREEMENT_PENDING
  AGREEMENT_SIGNED
  MILESTONE_1_APPROVED
  INSTALLMENT_1_RELEASED
  PROGRESS_REPORT_PENDING
  PROGRESS_REPORT_APPROVED
  MILESTONE_2_APPROVED
  INSTALLMENT_2_RELEASED
  FINAL_REPORT_PENDING
  FINAL_EVALUATION
  FELLOWSHIP_CLOSED
}

// Review section types
enum ReviewSectionType {
  SCIENTIFIC_VALIDITY
  CONTRIBUTION
  LITERATURE
  METHODOLOGY
  STATISTICS
  ETHICS
  INVESTIGATOR
  BUDGET
  EXPECTED_OUTCOMES
  FINAL_RECOMMENDATION
}

// Review question types
enum ReviewQuestionType {
  SCORE
  CHECKBOX
  TEXT
  SELECT
  TABLE
  CONFIDENCE_LEVEL
}

// Reviewer final recommendations
enum ReviewRecommendation {
  APPROVE
  APPROVE_WITH_MINOR_REVISION
  MAJOR_REVISION
  REJECT
  INTERVIEW_REQUIRED
}

// Interview recommendations from reviewers
enum InterviewRecommendation {
  NO_INTERVIEW
  RECOMMENDED
  STRONGLY_RECOMMENDED
  MANDATORY
}

// Budget review status
enum BudgetReviewStatus {
  APPROVED
  REDUCED
  REJECTED
  REQUIRES_REVISION
}

// Reviewer assignment status
enum ReviewerAssignmentStatus {
  PENDING
  ACCEPTED
  DECLINED
  IN_PROGRESS
  SUBMITTED
}

// Conflict of interest status
enum ConflictOfInterestStatus {
  DECLARED
  NO_CONFLICT
  PENDING
}

// Proposal version status
enum VersionStatus {
  ORIGINAL
  REVISED
  CLARIFICATION
}

model User {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  email         String   @unique
  phone         String?  @unique
  passwordHash   String   @map("password_hash")
  adminPassword  String?  @map("admin_password")
  role           UserRole @default(APPLICANT)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  profile              Profile?
  applications         Application[]
  committeeScores      CommitteeScore[]
  committeeRemarks     CommitteeRemark[]
  trusteeApprovals     TrusteeApproval[]
  reviewAssignments    ApplicationReviewAssignment[] @relation("ReviewerAssignments")
  queriesRaised        ApplicationQuery[]          @relation("QueriesRaised")
  notifications        Notification[]
  sessions             Session[]
  verificationSessions VerificationSession[]
  supportTickets       SupportTicket[]             @relation("SupportTicketApplicant")
  assignedSupportTickets SupportTicket[]           @relation("SupportTicketAssignee")
  supportTicketReplies SupportTicketReply[]
  auditLogs            AuditLog[]
  sentMessages         InboxMessage[] @relation("MessageSender")
  receivedMessages     InboxMessage[] @relation("MessageRecipient")
  
  // Review system relations
  completeReviews      CompleteReview[]
  proposalAnnotations   ProposalAnnotation[]
  conflictOfInterests  ConflictOfInterest[]
  committeeMatrixItems CommitteeMatrixItem[]
  enhancedAssignments  EnhancedReviewerAssignment[]
  budgetRecommendations BudgetRecommendation[]
  clarificationRequests ClarificationRequest[]

  @@map("users")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  name      String
  dob       DateTime?
  gender    Gender?
  address   String?
  city      String?
  state     String?
  country   String?  @default("India")
  pincode   String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Application {
  id                    String            @id @default(cuid())
  applicationNumber     String            @unique @map("application_number")
  userId                String            @map("user_id")
  status                ApplicationStatus @default(DRAFT)
  rejectionReason       String?           @map("rejection_reason")
  adminNotes            String?           @map("admin_notes")

  applicationType       String            @default("INDIVIDUAL") @map("application_type")
  groupMemberDetails    String?           @map("group_member_details")

  // New fields for Team / Official details
  teamName              String?           @map("team_name")
  teamMemberCount       Int?              @map("team_member_count")
  officialContactPerson String?           @map("official_contact_person")
  alternateMobile       String?           @map("alternate_mobile")
  officialPostalAddress  String?           @map("official_postal_address")
  ageProof              String?           @map("age_proof")
  identityProof         String?           @map("identity_proof")
  otherSupportingDocument String?          @map("other_supporting_document")

  // Personal Details
  name                  String
  dob                   DateTime
  gender                Gender
  address               String
  city                  String
  state                 String
  country               String            @default("India")
  pincode               String
  mobile                String
  email                 String

  // Professional Details
  bamsCollege           String            @map("bams_college")
  yearOfPassing         Int               @map("year_of_passing")
  mdMsPhdDetails        String?           @map("md_ms_phd_details")
  currentDesignation    String            @map("current_designation")
  institutionName       String            @map("institution_name")
  registrationCouncil   String            @map("registration_council")
  registrationNumber    String            @map("registration_number")
  yearsOfPractice       Int               @map("years_of_practice")
  viddhakarmaExperience String?           @map("viddhakarma_experience")
  publicationsSummary   String?           @map("publications_summary")
  termsAcceptedAt       DateTime?         @map("terms_accepted_at")
  undertakingAcceptedAt DateTime?         @map("undertaking_accepted_at")
  verificationNotes     String?           @map("verification_notes")
  identityVerificationStatus VerificationStatus @default(NOT_STARTED) @map("identity_verification_status")
  identityVerifiedAt    DateTime?         @map("identity_verified_at")
  eligibilityNotes      String?           @map("eligibility_notes")
  queryNotes            String?           @map("query_notes")
  queryPhase            String?           @map("query_phase")
  requiresResubmit      Boolean           @default(false) @map("requires_resubmit")

  submittedAt           DateTime?         @map("submitted_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  researchProposal  ResearchProposal?
  budget            Budget?
  documents         ApplicationDocument[]
  committeeScores   CommitteeScore[]
  committeeRemarks  CommitteeRemark[]
  interview         Interview?
  trusteeApproval   TrusteeApproval?
  fellowship        Fellowship?
  statusHistory     ApplicationStatusHistory[]
  digitalUndertaking DigitalUndertaking?
  reviewAssignments  ApplicationReviewAssignment[]
  applicationQueries ApplicationQuery[]
  verificationSessions VerificationSession[]
  inboxMessages      InboxMessage[]
  
  // Review system relations
  completeReviews      CompleteReview[]
  proposalVersions     ProposalVersion[]
  proposalAnnotations  ProposalAnnotation[]
  conflictOfInterests  ConflictOfInterest[]
  committeeMatrix      CommitteeMatrix?
  internalStatusHistory InternalStatusHistory[]
  enhancedAssignments  EnhancedReviewerAssignment[]
  duplicateProposals   DuplicateProposal[] @relation("FlaggedApplications")
  matchedDuplicates    DuplicateProposal[] @relation("MatchedApplications")
  clarificationRequests ClarificationRequest[]

  @@map("applications")
}

model ApplicationReviewAssignment {
  id            String      @id @default(cuid())
  applicationId String      @map("application_id")
  reviewerId    String      @map("reviewer_id")
  phase         ReviewPhase
  assignedBy    String?     @map("assigned_by")
  notes         String?
  assignedAt    DateTime    @default(now()) @map("assigned_at")
  isActive      Boolean     @default(true) @map("is_active")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer    User        @relation("ReviewerAssignments", fields: [reviewerId], references: [id])

  @@unique([applicationId, reviewerId, phase])
  @@map("application_review_assignments")
}

model ApplicationQuery {
  id                   String                 @id @default(cuid())
  applicationId        String                 @map("application_id")
  raisedBy             String                 @map("raised_by")
  phase                ReviewPhase
  message              String
  requiresFullResubmit Boolean                @default(false) @map("requires_full_resubmit")
  status               ApplicationQueryStatus @default(OPEN)
  applicantResponse    String?                @map("applicant_response")
  previousStatus       ApplicationStatus?     @map("previous_status")
  createdAt            DateTime               @default(now()) @map("created_at")
  respondedAt          DateTime?              @map("responded_at")
  resolvedAt           DateTime?              @map("resolved_at")

  application  Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  raisedByUser User        @relation("QueriesRaised", fields: [raisedBy], references: [id])

  @@map("application_queries")
}

model ApplicationStatusHistory {
  id            String            @id @default(cuid())
  applicationId String            @map("application_id")
  fromStatus    ApplicationStatus? @map("from_status")
  toStatus      ApplicationStatus @map("to_status")
  changedBy     String?           @map("changed_by")
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_status_history")
}

model DigitalUndertaking {
  id                   String   @id @default(cuid())
  applicationId        String   @unique @map("application_id")
  fullName             String   @map("full_name")
  agreeFellowshipRules Boolean  @map("agree_fellowship_rules")
  certifyInfoCorrect   Boolean  @map("certify_info_correct")
  agreeFundUtilization Boolean  @map("agree_fund_utilization")
  signaturePath        String   @map("signature_path")
  signatureType        String   @map("signature_type")
  pdfPath              String   @map("pdf_path")

  ipAddress            String   @map("ip_address")
  submittedAt          DateTime @default(now()) @map("submitted_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("digital_undertakings")
}

model FellowshipDocument {
  id              String            @id @default(cuid())
  fellowshipId    String            @map("fellowship_id")
  installmentNo   Int               @map("installment_no")
  type            FellowshipDocType
  fileName        String            @map("file_name")
  filePath        String            @map("file_path")

  fileSize        Int               @map("file_size")
  mimeType        String            @map("mime_type")
  status          DocumentStatus    @default(PENDING)
  rejectionReason String?           @map("rejection_reason")
  uploadedAt      DateTime          @default(now()) @map("uploaded_at")
  reviewedAt      DateTime?         @map("reviewed_at")
  reviewedBy      String?           @map("reviewed_by")

  fellowship Fellowship @relation(fields: [fellowshipId], references: [id], onDelete: Cascade)

  @@unique([fellowshipId, installmentNo, type])
  @@map("fellowship_documents")
}

model ResearchProposal {
  id                String       @id @default(cuid())
  applicationId     String       @unique @map("application_id")
  projectTitle      String       @map("project_title")
  researchArea      ResearchArea @map("research_area")
  researchAreaOther String?      @map("research_area_other")
  objectives        String
  methodology       String
  sampleSize        String       @map("sample_size")
  studyDuration     String       @map("study_duration")
  expectedOutcomes  String       @map("expected_outcomes")
  budgetSummary     String       @map("budget_summary")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("research_proposals")
}

model Budget {
  id            String   @id @default(cuid())
  applicationId String   @unique @map("application_id")
  equipment     Float    @default(0)
  consumables   Float    @default(0)
  travel        Float    @default(0)
  documentation Float    @default(0)
  publication   Float    @default(0)
  other         Float    @default(0)
  total         Float    @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("budgets")
}

model ApplicationDocument {
  id              String         @id @default(cuid())
  applicationId   String         @map("application_id")
  type            DocumentType
  fileName        String         @map("file_name")
  filePath        String         @map("file_path")

  fileSize        Int            @map("file_size")
  mimeType        String         @map("mime_type")
  status          DocumentStatus @default(PENDING)
  rejectionReason String?        @map("rejection_reason")
  uploadedAt      DateTime       @default(now()) @map("uploaded_at")
  reviewedAt      DateTime?      @map("reviewed_at")
  reviewedBy      String?        @map("reviewed_by")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_documents")
}

model CommitteeScore {
  id              String   @id @default(cuid())
  applicationId   String   @map("application_id")
  committeeUserId String   @map("committee_user_id")
  scientificMerit Float    @map("scientific_merit")
  innovation      Float
  feasibility     Float
  budgetJustification Float @map("budget_justification")
  viddhakarmaRelevance Float @map("viddhakarma_relevance")
  totalScore      Float    @map("total_score")
  remarks         String?
  isShortlisted   Boolean  @default(false) @map("is_shortlisted")
  isSubmitted     Boolean  @default(false) @map("is_submitted")
  submittedAt     DateTime? @map("submitted_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  committeeUser User        @relation(fields: [committeeUserId], references: [id])

  @@unique([applicationId, committeeUserId])
  @@map("committee_scores")
}

model ScoringCriteria {
  id          String @id @default(cuid())
  name        String @unique
  description String @map("description")
  maxScore    Float  @map("max_score")
  order       Int    @default(0)
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("scoring_criteria")
}

// New Dynamic Scoring System
model ApplicationScore {
  id              String   @id @default(cuid())
  applicationId   String   @map("application_id")
  reviewerId      String   @map("reviewer_id")
  reviewerName    String   @map("reviewer_name")
  isSubmitted     Boolean  @default(false) @map("is_submitted")
  isLocked        Boolean  @default(false) @map("is_locked")
  lockedAt        DateTime? @map("locked_at")
  totalScore      Float    @default(0) @map("total_score")
  maxPossibleScore Float   @default(100) @map("max_possible_score")
  remarks         String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scores        ApplicationScoreItem[]

  @@unique([applicationId, reviewerId])
  @@map("application_scores")
}

model ApplicationScoreItem {
  id              String   @id @default(cuid())
  scoreId         String   @map("score_id")
  criteriaId      String   @map("criteria_id")
  criteriaName    String   @map("criteria_name")
  criteriaDescription String @map("criteria_description")
  maxScore        Float   @map("max_score")
  score           Float   @map("score")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  applicationScore ApplicationScore @relation(fields: [scoreId], references: [id], onDelete: Cascade)

  @@unique([scoreId, criteriaId])
  @@map("application_score_items")
}

model CommitteeRemark {
  id              String   @id @default(cuid())
  applicationId   String   @map("application_id")
  committeeUserId String   @map("committee_user_id")
  remark          String
  createdAt       DateTime @default(now()) @map("created_at")

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  committeeUser User        @relation(fields: [committeeUserId], references: [id])

  @@map("committee_remarks")
}

model Interview {
  id            String   @id @default(cuid())
  applicationId String   @unique @map("application_id")
  interviewType InterviewType @default(ONLINE) @map("interview_type")
  
  // Schedule
  scheduledDate DateTime @map("scheduled_date")
  scheduledTime String   @map("scheduled_time")
  durationMinutes Int    @default(30) @map("duration_minutes")
  
  // Online meeting details
  meetingLink   String?  @map("meeting_link")
  meetingRoomId String?  @map("meeting_room_id")
  mirotalkRoom  String?  @map("mirotalk_room")
  
  // In-person location details
  location      String?  @map("location")
  address       String?  @map("address")
  googleMapsUrl String?  @map("google_maps_url")
  
  // Panel info
  panelMembers  String   @map("panel_members")
  
  // Status and feedback
  status        InterviewStatus @default(SCHEDULED)
  feedback      String?
  notes         String?
  
  // Tracking
  previousScheduledDate DateTime? @map("previous_scheduled_date")
  previousScheduledTime String?   @map("previous_scheduled_time")
  cancellationReason    String?   @map("cancellation_reason")
  
  // Notifications
  applicantNotifiedAt   DateTime? @map("applicant_notified_at")
  reminderSentAt        DateTime? @map("reminder_sent_at")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("interviews")
}

model TrusteeApproval {
  id              String   @id @default(cuid())
  applicationId   String   @unique @map("application_id")
  trusteeUserId   String   @map("trustee_user_id")
  approved        Boolean
  remarks         String?
  digitalSignature String? @map("digital_signature")
  approvedAt      DateTime @default(now()) @map("approved_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  trusteeUser User        @relation(fields: [trusteeUserId], references: [id])

  @@map("trustee_approvals")
}

model Fellowship {
  id               String   @id @default(cuid())
  fellowshipId     String   @unique @map("fellowship_id")
