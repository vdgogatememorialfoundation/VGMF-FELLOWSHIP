DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
JWT_SECRET="change-this-to-a-long-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Render keep-alive (production only; disabled locally by default)
# SELF_KEEPALIVE_ENABLED="true"
# KEEPALIVE_URL="https://fellowship.vaidyagogate.org/api/health"
# KEEPALIVE_INTERVAL_MS="720000"

# ZeptoMail (https://www.zoho.com/zeptomail/)
ZEPTOMAIL_TOKEN="Zoho-enczapikey YOUR_SEND_MAIL_TOKEN"
ZEPTOMAIL_FROM_EMAIL="noreply@yourdomain.com"
ZEPTOMAIL_FROM_NAME="VGMF Fellowship Portal"
# India ZeptoMail (default). Global accounts: ZEPTOMAIL_API_URL="https://api.zeptomail.com/v1.1/email"
ZEPTOMAIL_API_URL="https://api.zeptomail.in/v1.1/email"

# Meta WhatsApp Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api)
WHATSAPP_TOKEN="your_meta_permanent_access_token"
WHATSAPP_PHONE_NUMBER_ID="your_phone_number_id"
WHATSAPP_BUSINESS_ACCOUNT_ID="your_waba_id"
WHATSAPP_OTP_TEMPLATE_NAME="vgmf_otp_auth"
WHATSAPP_OTP_TEMPLATE_LANGUAGE="en"
WHATSAPP_API_VERSION="v22.0"

# Digio DigiKYC & bank verification (https://documentation.digio.in/)
DIGIO_CLIENT_ID="your_digio_client_id"
DIGIO_CLIENT_SECRET="your_digio_client_secret"
DIGIO_WEBHOOK_SECRET="your_digio_webhook_secret"
DIGIO_TEMPLATE_IDENTITY=""
DIGIO_DEFAULT_IDENTITY_TEMPLATE="DIGILOCKER_AADHAAR_PAN"
DIGIO_TEMPLATE_BANK=""
DIGIO_TEMPLATE_UNDERTAKING=""
DIGIO_ENVIRONMENT="production"
NEXT_PUBLIC_DIGIO_WEB_SDK_VERSION="v11"
DIGIO_REQUIRE_IDENTITY_FOR_SCRUTINY="false"
DIGIO_ENABLED="true"
